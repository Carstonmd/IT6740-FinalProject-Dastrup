const { GoogleGenAI, Type } = require('@google/genai');
const fs = require('fs');
const path = require('path');
const readline = require('readline');
require('dotenv').config(); 

// Initialize the Gemini client securely from your environment variables
const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });

// Strict JSON structure schema to enforce factual reporting and eliminate hallucinations
const triageResponseSchema = {
  type: Type.OBJECT,
  properties: {
    severity: { 
      type: Type.STRING, 
      enum: ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
      description: "The assessed threat level of the log activity."
    },
    mitreAttackMapping: {
      type: Type.STRING,
      description: "Relevant MITRE ATT&CK technique ID (e.g., T1571) or 'None'."
    },
    confidenceScore: {
      type: Type.INTEGER,
      description: "Confidence rating from 0 to 100 regarding anomaly accuracy."
    },
    summaryAnalysis: { 
      type: Type.STRING, 
      description: "A concise, technical breakdown of what the device is doing."
    },
    isAnomalous: { 
      type: Type.BOOLEAN,
      description: "True if the log indicates behavioral deviation from normal IoT operations."
    }
  },
  required: ["severity", "mitreAttackMapping", "confidenceScore", "summaryAnalysis", "isAnomalous"],
};

/**
 * Sends a specific chunk of Zeek log entries to Gemini for analysis and appends the result to a JSON file
 */
async function triageLogChunk(logChunk, chunkNumber, fileName, outputFile) {
  try {
    const cleanFolderName = path.basename(path.dirname(fileName));
    console.log(`[+] Sending Chunk #${chunkNumber} from [${cleanFolderName}] to Gemini...`);
    
    const response = await ai.models.generateContent({
      model: 'gemini-2.5-flash', // High throughput, low latency model optimized for parsing
      contents: `Analyze the following raw IoT Zeek network log records and evaluate for anomalies or malicious vectors:\n\n${logChunk}`,
      config: {
        systemInstruction: "You are an expert automated SOC triage agent specializing in unmanaged IoT endpoints and Zeek/Bro log anomalies. Analyze the telemetry accurately based strictly on facts.",
        responseMimeType: "application/json",
        responseSchema: triageResponseSchema,
        temperature: 0.1, 
      },
    });

    // 1. Parse the structural string back into a temporary JS Object
    const triageReport = JSON.parse(response.text);
    
    // 2. Inject structural metadata tracking so Splunk has perfect dashboard telemetry
    triageReport.timestamp = new Date().toISOString();
    triageReport.source_log = cleanFolderName;
    triageReport.chunk_id = chunkNumber;

    // 3. Flatten the object to a single line with an explicit trailing newline (NDJSON)
    const splunkReadyLine = JSON.stringify(triageReport) + '\n';

    // 4. Append directly to the master output file that Splunk can monitor natively
    fs.appendFileSync(outputFile, splunkReadyLine);
    console.log(`    [✓] Chunk #${chunkNumber} triage saved successfully.`);
    
    return triageReport;

  } catch (error) {
    console.error(`[-] Error during Gemini triage on Chunk #${chunkNumber}:`, error.message);
  }
}

/**
 * Streams and chunks a local Zeek log file line-by-line until completion
 * @param {string} filePath - Path to your conn.log.labeled file
 * @param {string} outputFile - Path to the destination .json file
 * @param {number} linesPerChunk - How many log entries to send at once
 */
async function processFullZeekLogFile(filePath, outputFile, linesPerChunk = 100) {
  const fileStream = fs.createReadStream(filePath);
  const rl = readline.createInterface({ input: fileStream, crlfDelay: Infinity });

  let headerLines = "";
  let currentChunkLines = [];
  let chunkCount = 1;
  const folderName = path.basename(path.dirname(filePath));

  console.log(`\n[+] Starting FULL processing for folder: ${folderName}`);
  console.log(`[+] Input File: ${filePath}`);
  console.log(`[+] Target Output Log: ${outputFile}\n`);

  for await (const line of rl) {
    // Retain original Zeek structural annotations so Gemini can track schema headers dynamically
    if (line.startsWith('#')) {
      headerLines += line + '\n';
      continue;
    }

    currentChunkLines.push(line);

    // Once threshold is reached, bundle headers with the log data and send it off
    if (currentChunkLines.length >= linesPerChunk) {
      const logPayload = headerLines + currentChunkLines.join('\n');
      await triageLogChunk(logPayload, chunkCount, filePath, outputFile);
      
      currentChunkLines = [];
      chunkCount++;
      
      // Safety note: If you run into TPM (Tokens Per Minute) limit errors on very huge logs,
      // you can add a short cooling delay between chunks by uncommenting this line:
      // await new Promise(resolve => setTimeout(resolve, 2000));
    }
  }

  // Process leftover entries at the bottom of the log file
  if (currentChunkLines.length > 0) {
    const logPayload = headerLines + currentChunkLines.join('\n');
    await triageLogChunk(logPayload, chunkCount, filePath, outputFile);
  }

  console.log(`\n[✓] COMPLETED file parsing for ${folderName}. Total Chunks analyzed: ${chunkCount}`);
}

/**
 * Scans the base directory to find all available valid log files and processes them
 */
async function runFullPipeline() {
  const baseDir = "G:/School/FinalProject6740/iot_23_datasets_full/opt/Malware-Project/BigDataset/IoTScenarios";
  const outputFile = "./splunk_gemini_triage.json"; // This will gather all logs in NDJSON format

  if (!fs.existsSync(baseDir)) {
    console.error(`[-] Base directory not found! Check your drive letter or path format:\n    ${baseDir}`);
    return;
  }

  console.log(`[+] Scanning base directory for capture scenarios...`);
  const items = fs.readdirSync(baseDir);

  for (const item of items) {
    const fullPath = path.join(baseDir, item);
    
    // Check if the item is a folder (like CTU-IoT-Malware-Capture-x-x)
    if (fs.statSync(fullPath).isDirectory()) {
      const possiblePaths = [
        path.join(fullPath, "conn.log.labeled"),
        path.join(fullPath, "bro", "conn.log.labeled")
      ];

      for (const logFile of possiblePaths) {
        if (fs.existsSync(logFile)) {
          // Process this entire file from start to finish
          await processFullZeekLogFile(logFile, outputFile, 100);
          
          // SAFETY BARRIER: 
          // Keeping this 'return' processes exactly ONE complete capture scenario folder at a time 
          // so you can manage your file output sizes and look at the logs.
          // If you want it to run through all 23 scenarios completely unattended, simply comment out the 'return;' below!
          console.log(`\n[!] Pipeline paused after completing the first full folder scenario.`);
          console.log(`[!] Review your './splunk_gemini_triage.json' file. Remove 'return;' to run through remaining scenarios.`);
          //return; 
        }
      }
    }
  }
}

// Start the processing engine
runFullPipeline();